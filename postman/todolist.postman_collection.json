      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 401', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Contrato de erro de autenticacao', function () {",
              "    pm.expect(jsonData.status).to.eql(401);",
              "    pm.expect(jsonData.code).to.eql('AUTH_TOKEN_MISSING');",
              "    pm.expect(jsonData.action).to.eql('LOGIN');",
              "});"
            ]
          }
        }
      ]
    },
