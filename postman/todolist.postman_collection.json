    {
      "key": "usuarioId",
      "value": "1"
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "admin123"
    },
    {
      "key": "currentPassword",
      "value": "admin123"
    },
    {
      "key": "newPassword",
      "value": "admin12345"
    }
  ],
