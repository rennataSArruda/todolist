                    "type": "text/javascript",
                    "exec": [
                        "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                        "var jsonData = pm.response.json();",
                        "pm.test('Retorna dados do usuario autenticado', function () {",
                        "    pm.expect(jsonData.id).to.exist;",
                        "    pm.expect(jsonData.username).to.be.a('string').and.not.empty;",
                        "    pm.expect(jsonData.nome).to.be.a('string').and.not.empty;",
                        "    pm.expect(jsonData.perfil).to.be.an('object');",
                        "    pm.expect(jsonData.perfil.id).to.exist;",
                        "    pm.expect(jsonData.perfil.codigo).to.be.a('string').and.not.empty;",
                        "    pm.expect(jsonData.authorities).to.be.an('array');",
                        "    pm.expect(jsonData.root).to.be.a('boolean');",
                        "});"
                    ]
                }
            }]
